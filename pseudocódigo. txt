algoritmo "Aluno rpv,apv,rec"

var
   p, s, t, m : real
   nome, situacao: caractere
funcao calcularmedia (n1, n2, n3: real): real
var
   resultado : real
inicio
      resultado <- (n1 + n2 + n3)/3
      retorne resultado
fimfuncao

funcao definirsituacao (media :real):caractere
inicio
      se (media >= 7 ) entao
         retorne "APROVADO"
      senao
           se media >= 5 entao
            retorne "RECUPERAÇÃO"
      senao
           retorne "REPROVADO"
           fimse
      fimse
      
fimfuncao
inicio
   escreval ("----------------------------")
   escreval ("     ESCOLA DO RAIMUNDO     ")
   escreval ("----------------------------")
   escreva ("Digite o nome do aluno (a): ")
   leia (nome)
   escreva ("Primeira nota: ")
   leia (p)
   escreva ("Segunda nota: ")
   leia (s)
   escreva ("Terceira nota: ")
   leia (t)
   m <- calcularmedia (p, s, t)
   escreval ("----------------------------")
   escreval ("A média do aluno (a) ", nome, " foi: ", m:4:2)
    se (m >= 9) entao
      escreval("APROVEITAMENTO: A")
   senao
      se (m >= 8) entao
         escreval("APROVEITAMENTO: B")
      senao
         se (m >= 7) entao
            escreval("APROVEITAMENTO: C")
         senao
            se (m >= 6) entao
               escreval ("APROVEITAMENTO: D")
            senao
               se (m >= 5) entao
                  escreval ("APROVEITAMENTO: E")
               senao
                  se (m < 5)entao
                     escreval ("APROVEITAMENTO: F")

                  FimSe
               FimSe
            FimSe
         FimSe
      FimSe
   Fimse

   situacao <- definirsituacao (m)
   escreval ("Situação: ", situacao)
   escreval ("----------------------------")


fimalgoritmo
